@model FocusSpace.Application.DTOs.TaskDto
@using FocusSpace.Domain.Enums
@{
    ViewData["Title"] = Model.Title;

    string priorityBadge = Model.Priority switch
    {
        TaskPriority.High   => "badge bg-danger",
        TaskPriority.Medium => "badge bg-warning text-dark",
        TaskPriority.Low    => "badge bg-secondary",
        _                   => "badge bg-secondary"
    };
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card p-4">
            <h4 class="mb-1">📋 @Model.Title</h4>
            <p class="text-muted small mb-4">Created @Model.CreatedAt.ToString("dd MMMM yyyy, HH:mm") UTC</p>

            <dl class="row">
                <dt class="col-sm-3 text-muted">Priority</dt>
                <dd class="col-sm-9">
                    <span class="@priorityBadge">@Model.Priority</span>
                </dd>

                <dt class="col-sm-3 text-muted">Description</dt>
                <dd class="col-sm-9">@(Model.Description ?? "No description provided.")</dd>

                <dt class="col-sm-3 text-muted">Last updated</dt>
                <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd MMMM yyyy, HH:mm") UTC</dd>
            </dl>

            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit"   asp-route-id="@Model.Id" class="btn btn-outline-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
                <a asp-action="Index"                           class="btn btn-outline-secondary ms-auto">← Back to list</a>
            </div>
        </div>
    </div>
</div>
