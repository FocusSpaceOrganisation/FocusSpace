<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FocusSpace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        :root {
            --dark-amethyst: #231942ff;
            --dusty-grape: #5e548eff;
            --amethyst-smoke: #9f86c0ff;
            --lilac: #be95c4ff;
            --pink-orchid: #e0b1cbff;
            --dark-button: #3e2c5aff;
            --dark-button-hover: #2e1c4aff;
            --text-primary: #f5e6faff;
            --text-secondary: #d1c4e9ff;
            --text-muted: #b39ddbff;
            --text-danger: #ff8a80ff;
            --text-success: #a5d6a7ff;
            --text-info: #90caf9ff;
        }

        body { background: var(--dark-amethyst); color: var(--text-primary); }
        .navbar { background: var(--dusty-grape) !important; }
        .navbar-brand { color: var(--text-primary) !important; font-weight: 700; letter-spacing: 1px; }
        .card { background: var(--amethyst-smoke); border: 1px solid var(--dusty-grape); }
        .btn-primary { background: var(--dark-button); border-color: var(--dark-button); color: var(--text-primary); font-weight: 600; }
        .btn-primary:hover { background: var(--dark-button-hover); border-color: var(--dark-button-hover); color: var(--text-primary); }
        .table { color: var(--text-primary); }
        .table-hover tbody tr:hover { background: var(--dusty-grape); color: var(--text-primary); }
        .table th { color: var(--text-primary); background: var(--dusty-grape); border-color: var(--dusty-grape); }
        .table td { border-color: var(--dusty-grape); }
        a { color: var(--text-info); text-decoration: none; }
        a:hover { color: var(--text-primary); text-decoration: underline; }
        h1, h2, h3, h4, h5, h6 { color: var(--text-primary) !important; }
        .form-control { background: var(--amethyst-smoke) !important; color: var(--text-secondary) !important; border-color: var(--dusty-grape) !important; }
        .form-control:focus { border-color: var(--lilac) !important; box-shadow: 0 0 0 .2rem rgba(190,149,196,.25) !important; color: var(--text-primary) !important; }
        .form-label { color: var(--text-primary) !important; font-weight: 500; }
        .form-text { color: var(--text-muted) !important; }
        .form-check-input { background: var(--amethyst-smoke); border-color: var(--dusty-grape); }
        .form-check-input:checked { background: var(--dark-button); border-color: var(--dark-button); }
        .form-check-label { color: var(--text-secondary) !important; }
        .btn-outline-secondary { color: var(--text-primary); border-color: var(--dusty-grape); background: var(--dusty-grape); }
        .btn-outline-secondary:hover { background: var(--lilac); border-color: var(--lilac); color: var(--dark-amethyst); }
        .btn-outline-warning { color: var(--dark-amethyst); border-color: #fbbf24; background: #fbbf24; font-weight: 600; }
        .btn-outline-warning:hover { background: #fcd34d; border-color: #fcd34d; color: var(--dark-amethyst); }
        .btn-outline-danger { color: #fff; border-color: var(--text-danger); background: var(--text-danger); font-weight: 600; }
        .btn-outline-danger:hover { background: #ff6b6b; border-color: #ff6b6b; color: #fff; }
        .dropdown-menu { background: var(--amethyst-smoke) !important; border-color: var(--dusty-grape) !important; }
        .dropdown-item { color: var(--text-secondary) !important; }
        .dropdown-item:hover { background: var(--dark-button-hover) !important; color: var(--text-primary) !important; }
        .alert-info { background: var(--dusty-grape); border-color: var(--lilac); color: var(--text-info); }
        .alert-success { background: var(--amethyst-smoke); border-color: var(--lilac); color: var(--text-success); }
        .alert-danger { background: var(--dusty-grape); border-color: var(--pink-orchid); color: var(--text-danger); }
        .modal-content { background: var(--dark-amethyst); border: 1px solid var(--dusty-grape); color: var(--text-primary); }
        .modal-header { background: var(--dusty-grape); border-bottom: 1px solid var(--lilac); color: var(--text-primary); }
        .modal-header .btn-close { filter: invert(1); }
        .modal-body { background: var(--dark-amethyst); color: var(--text-primary); }
        .modal-body p { color: var(--text-secondary); }
        .modal-footer { background: var(--dark-amethyst); border-top: 1px solid var(--dusty-grape); }
        .btn-secondary { background: var(--dark-button); border-color: var(--dark-button); color: var(--text-primary); }
        .btn-secondary:hover { background: var(--dark-button-hover); border-color: var(--dark-button-hover); color: var(--text-primary); }
        label { color: var(--text-primary); font-weight: 500; }
        .small, .text-small { color: var(--text-muted); }

        /* ── Session History Modal ── */
        #sessionHistoryModal .modal-dialog {
            max-width: 720px;
        }

        .session-row {
            background: rgba(94, 84, 142, 0.25);
            border: 1px solid var(--dusty-grape);
            border-radius: 10px;
            padding: 14px 16px;
            margin-bottom: 10px;
            transition: background 0.2s;
        }
        .session-row:hover {
            background: rgba(94, 84, 142, 0.45);
        }
        .session-status {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .5px;
            text-transform: uppercase;
        }
        .status-completed  { background: #388e3c; color: #fff; }
        .status-ongoing    { background: #1565c0; color: #fff; }
        .status-paused     { background: #f57c00; color: #fff; }
        .status-aborted    { background: #c62828; color: #fff; }

        .session-meta { color: var(--text-muted); font-size: 12px; margin-top: 4px; }

        #sessionHistoryLoading { text-align: center; padding: 40px; color: var(--text-muted); }
        #sessionHistoryEmpty   { text-align: center; padding: 40px; color: var(--text-muted); }

        .session-filter-tabs { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
        .session-filter-btn {
            padding: 6px 14px; border: 1px solid var(--dusty-grape); border-radius: 20px;
            background: transparent; color: var(--text-muted); cursor: pointer; font-size: 13px;
            transition: all .2s;
        }
        .session-filter-btn.active {
            background: var(--dusty-grape); color: var(--text-primary); border-color: var(--lilac);
        }
        .session-filter-btn:hover:not(.active) {
            background: rgba(94,84,142,.3); color: var(--text-primary);
        }

        .session-modal-body { max-height: 65vh; overflow-y: auto; padding-right: 4px; }
        .session-modal-body::-webkit-scrollbar { width: 6px; }
        .session-modal-body::-webkit-scrollbar-track { background: transparent; }
        .session-modal-body::-webkit-scrollbar-thumb { background: var(--dusty-grape); border-radius: 3px; }

        /* existing styles kept below */
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🚀 FocusSpace</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-1">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" style="color:#fbbf24"
                                   asp-controller="Admin" asp-action="Index">
                                    Admin Panel
                                </a>
                            </li>
                        }

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-light" href="#"
                               id="userDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger"
                                                style="background:transparent;border:none;width:100%;text-align:left;padding:8px 16px;cursor:pointer">
                                            Log Out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-light" href="#" id="menuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Menu
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="menuDropdown">
                                <li>
                                    <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#aboutUsModal">About Us</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#myAccountModal">My Account</a>
                                </li>
                                <li><hr class="dropdown-divider" style="border-color:var(--dusty-grape)"></li>
                                <li>
                                    <a class="dropdown-item" href="#" id="openSessionHistoryBtn">
                                        📋 Session History
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Account" asp-action="Login">Log In</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm ms-2" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @success
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @error
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Info"] is string info)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @info
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!-- ════════════════════════════════════════════════════════════
     SESSION HISTORY MODAL
════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="sessionHistoryModal" tabindex="-1" aria-labelledby="sessionHistoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="sessionHistoryModalLabel">📋 Session History</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 20px 24px;">

                <!-- Filter tabs -->
                <div class="session-filter-tabs" id="sessionFilterTabs">
                    <button class="session-filter-btn active" data-filter="all">All</button>
                    <button class="session-filter-btn" data-filter="Completed">✅ Completed</button>
                    <button class="session-filter-btn" data-filter="Ongoing">🔵 Ongoing</button>
                    <button class="session-filter-btn" data-filter="Paused">⏸ Paused</button>
                    <button class="session-filter-btn" data-filter="Aborted">❌ Aborted</button>
                </div>

                <!-- Summary row -->
                <div id="sessionSummary" style="display:none; margin-bottom:14px; color:var(--text-muted); font-size:13px;">
                    Total: <strong id="sumTotal" style="color:var(--text-primary)">0</strong> sessions &nbsp;|&nbsp;
                    Focus time: <strong id="sumFocus" style="color:#a78bfa">0 min</strong>
                </div>

                <!-- Loading / empty states -->
                <div id="sessionHistoryLoading">Loading sessions…</div>
                <div id="sessionHistoryEmpty" style="display:none;">No sessions found.</div>

                <!-- Session list -->
                <div class="session-modal-body">
                    <div id="sessionHistoryList"></div>
                </div>
            </div>
            <div class="modal-footer" style="justify-content:flex-start; padding: 12px 24px;">
                <span style="color:var(--text-muted); font-size:12px;">Showing your personal focus sessions</span>
                <button type="button" class="btn btn-secondary ms-auto" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- About Us Modal -->
<div class="modal fade" id="aboutUsModal" tabindex="-1" aria-labelledby="aboutUsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="aboutUsModalLabel">About Us</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Welcome to FocusSpace! We are dedicated to helping you stay productive and organized.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- My Account Modal -->
<div class="modal fade" id="myAccountModal" tabindex="-1" aria-labelledby="myAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="myAccountModalLabel">My Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Manage your account settings and preferences here.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>


<script>
// ── Session History ────────────────────────────────────────────────
(function () {
    let allSessions = [];
    let currentFilter = 'all';

    const modalEl      = document.getElementById('sessionHistoryModal');
    const listEl       = document.getElementById('sessionHistoryList');
    const loadingEl    = document.getElementById('sessionHistoryLoading');
    const emptyEl      = document.getElementById('sessionHistoryEmpty');
    const summaryEl    = document.getElementById('sessionSummary');
    const sumTotalEl   = document.getElementById('sumTotal');
    const sumFocusEl   = document.getElementById('sumFocus');
    const openBtn      = document.getElementById('openSessionHistoryBtn');

    if (!openBtn) return; // not authenticated

    // Open modal + load data
    openBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const bsModal = new bootstrap.Modal(modalEl);
        bsModal.show();
        loadSessions();
    });

    // Filter buttons
    document.getElementById('sessionFilterTabs')?.querySelectorAll('.session-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.session-filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentFilter = btn.dataset.filter;
            renderSessions();
        });
    });

    async function loadSessions() {
        listEl.innerHTML = '';
        loadingEl.style.display = 'block';
        emptyEl.style.display   = 'none';
        summaryEl.style.display  = 'none';

        try {
            const res = await fetch('/Session/GetUserSessions');
            if (!res.ok) throw new Error('Failed to load');
            allSessions = await res.json();
            renderSessions();
        } catch {
            loadingEl.textContent = '⚠️ Could not load session history.';
        }
    }

    function renderSessions() {
        loadingEl.style.display = 'none';

        const filtered = currentFilter === 'all'
            ? allSessions
            : allSessions.filter(s => s.status === currentFilter);

        if (filtered.length === 0) {
            emptyEl.style.display  = 'block';
            summaryEl.style.display = 'none';
            listEl.innerHTML = '';
            return;
        }

        emptyEl.style.display = 'none';

        // Summary
        const totalMinutes = filtered.reduce((acc, s) => {
            if (!s.actualDuration) return acc;
            const parts = s.actualDuration.split(':').map(Number);
            return acc + (parts[0] * 60) + parts[1] + Math.round(parts[2] / 60);
        }, 0);

        sumTotalEl.textContent = filtered.length;
        sumFocusEl.textContent = totalMinutes >= 60
            ? `${Math.floor(totalMinutes / 60)}h ${totalMinutes % 60}m`
            : `${totalMinutes} min`;
        summaryEl.style.display = 'block';

        listEl.innerHTML = filtered.map(s => {
            const statusClass = `status-${s.status.toLowerCase()}`;
            const start = new Date(s.startTime);
            const dateStr = start.toLocaleDateString('uk-UA', { day: '2-digit', month: 'short', year: 'numeric' });
            const timeStr = start.toLocaleTimeString('uk-UA', { hour: '2-digit', minute: '2-digit' });

            const planned  = formatDuration(s.plannedDuration);
            const actual   = s.actualDuration ? formatDuration(s.actualDuration) : '—';
            const taskBadge = s.taskTitle
                ? `<span style="color:var(--lilac);font-size:12px;">📌 ${escHtml(s.taskTitle)}</span>`
                : `<span style="color:var(--text-muted);font-size:12px;">No task</span>`;

            return `
            <div class="session-row">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <span class="session-status ${statusClass}">${s.status}</span>
                        &nbsp; ${taskBadge}
                    </div>
                    <div style="color:var(--text-muted);font-size:12px;">${dateStr}, ${timeStr}</div>
                </div>
                <div class="session-meta mt-2 d-flex gap-3 flex-wrap">
                    <span>🎯 Planned: <strong style="color:var(--text-primary)">${planned}</strong></span>
                    <span>⏱ Actual: <strong style="color:var(--text-primary)">${actual}</strong></span>
                </div>
            </div>`;
        }).join('');
    }

    function formatDuration(ts) {
        if (!ts) return '—';
        // ts may arrive as "HH:MM:SS" or ISO 8601 duration
        const parts = ts.split(':');
        if (parts.length === 3) {
            const h = parseInt(parts[0]), m = parseInt(parts[1]);
            if (h > 0) return `${h}h ${m}m`;
            return `${m}m`;
        }
        return ts;
    }

    function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
})();

</script>
