@{
    ViewData["Title"] = "FocusSpace";
}
@model List<FocusSpace.Domain.Entities.Planet>
@using System.Globalization

@{
    var planets = (Model ?? new List<FocusSpace.Domain.Entities.Planet>())
        .OrderBy(p => p.OrderNumber)
        .ToList();

    const double centerX = 510;
    const double centerY = 360;

    var minOrbit = 145d;
    var maxOrbit = 300d;
    var orbitStep = planets.Count > 1
        ? (maxOrbit - minOrbit) / (planets.Count - 1)
        : 0d;

    var colorPairs = new[]
    {
        ("#b8b8b8", "#6d6d6d"),
        ("#ffd784", "#efab3a"),
        ("#91d8ff", "#2275d9"),
        ("#f6a27f", "#c0501e"),
        ("#d4a06a", "#8f6038"),
        ("#f2d9aa", "#c49a67"),
        ("#87f0ff", "#2db2c6"),
        ("#7594ff", "#2f4ab8")
    };

    double GetPlanetSize(int index)
    {
        var sizes = new[] { 11d, 16d, 20d, 14d, 30d, 24d, 18d, 18d };
        if (index < sizes.Length) return sizes[index];
        return 14d + (index % 5) * 2d;
    }

    string GetPlanetType(string name)
    {
        var n = (name ?? string.Empty).Trim().ToLowerInvariant();
        if (n is "mercury" or "venus" or "earth" or "mars") return "Rocky";
        if (n is "jupiter" or "saturn") return "Gas Giant";
        if (n is "uranus" or "neptune") return "Ice Giant";
        return "Exoplanet";
    }

    string GetTypeClass(string type)
    {
        return type switch
        {
            "Rocky" => "type-rocky",
            "Gas Giant" => "type-gas",
            "Ice Giant" => "type-ice",
            _ => "type-exo"
        };
    }

    (double x, double y) GetPoint(double orbitRadius, double angleDeg)
    {
        var angleRad = Math.PI * angleDeg / 180.0;
        return (
            centerX + orbitRadius * Math.Cos(angleRad),
            centerY + orbitRadius * Math.Sin(angleRad)
        );
    }
}

<form id="af-form" style="display:none">
    @Html.AntiForgeryToken()
</form>

<div class="space-stage">
    <svg id="planet-visualization"
         width="100%"
         height="100%"
         viewBox="0 0 1020 820"
         preserveAspectRatio="xMidYMid meet"
         data-center-x="510"
         data-center-y="360">

        <defs>
            @for (var i = 0; i < planets.Count; i++)
            {
                var pair = colorPairs[i % colorPairs.Length];
                <radialGradient id="planetGradient-@i" cx="35%" cy="35%">
                    <stop offset="0%" style="stop-color:@pair.Item1;stop-opacity:1" />
                    <stop offset="100%" style="stop-color:@pair.Item2;stop-opacity:1" />
                </radialGradient>
            }
            <radialGradient id="sunGradient" cx="40%" cy="40%">
                <stop offset="0%" style="stop-color:#fdb813;stop-opacity:1" />
                <stop offset="70%" style="stop-color:#fdb813;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#fd8813;stop-opacity:1" />
            </radialGradient>
        </defs>

        @for (var i = 0; i < planets.Count; i++)
        {
            var orbit = minOrbit + i * orbitStep;
            var opacity = Math.Max(0.12, 0.34 - i * 0.03);
            <circle cx="@centerX"
                    cy="@centerY"
                    r="@orbit.ToString("0.###", CultureInfo.InvariantCulture)"
                    fill="none"
                    stroke="#7c3aed"
                    stroke-width="1"
                    opacity="@opacity.ToString("0.###", CultureInfo.InvariantCulture)" />
        }

        <circle cx="@centerX" cy="@centerY" r="50" fill="url(#sunGradient)" />
        <circle cx="@centerX" cy="@centerY" r="50" fill="#000" opacity="0.1" />

        <g id="planets-orbit" style="animation: rotate 70s linear infinite; transform-origin: 510px 360px;">
            @for (var i = 0; i < planets.Count; i++)
            {
                var planet = planets[i];
                var orbit = minOrbit + i * orbitStep;
                var angle = planets.Count == 1 ? -90d : -90d + (360d / planets.Count) * i;
                var point = GetPoint(orbit, angle);
                var size = GetPlanetSize(i);
                var type = GetPlanetType(planet.Name);
                var typeClass = GetTypeClass(type);
                var cx = point.x.ToString("0.###", CultureInfo.InvariantCulture);
                var cy = point.y.ToString("0.###", CultureInfo.InvariantCulture);
                var radius = size.ToString("0.###", CultureInfo.InvariantCulture);
                var desc = planet.Description ?? string.Empty;
                var distance = planet.DistanceFromPrevious?.ToString() ?? string.Empty;
                <g class="planet @typeClass"
                   data-id="@planet.Id"
                   data-name="@planet.Name"
                   data-type="@type"
                   data-order="@planet.OrderNumber"
                   data-description="@desc"
                   data-distance="@distance"
                   data-cx="@cx"
                   data-cy="@cy"
                   data-radius="@radius"
                   tabindex="0"
                   role="button"
                   aria-label="Planet @planet.Name">
                    <circle cx="@cx" cy="@cy" r="@radius" fill="url(#planetGradient-@i)" />
                    <circle cx="@cx" cy="@cy" r="@radius" fill="#000" opacity="0.15" />
                    @if (type == "Rocky")
                    {
                        <circle cx="@(point.x - size * 0.25)" cy="@(point.y - size * 0.18)" r="@(Math.Max(1d, size * 0.12))" fill="#2c2c2c" opacity="0.45" />
                        <circle cx="@(point.x + size * 0.18)" cy="@(point.y + size * 0.12)" r="@(Math.Max(1d, size * 0.09))" fill="#2c2c2c" opacity="0.4" />
                        <circle cx="@(point.x + size * 0.05)" cy="@(point.y - size * 0.28)" r="@(Math.Max(1d, size * 0.07))" fill="#f1e3bf" opacity="0.35" />
                    }
                    else if (type == "Gas Giant")
                    {
                        <ellipse cx="@cx"
                                 cy="@cy"
                                 rx="@(size * 1.68)"
                                 ry="@(Math.Max(5d, size * 0.42))"
                                 fill="none"
                                 stroke="#f1d1a0"
                                 stroke-width="2"
                                 opacity="0.5" />
                        <ellipse cx="@cx"
                                 cy="@cy"
                                 rx="@(size * 0.95)"
                                 ry="@(Math.Max(2d, size * 0.14))"
                                 fill="#ffffff"
                                 opacity="0.10" />
                    }
                    else if (type == "Ice Giant")
                    {
                        <ellipse cx="@cx"
                                 cy="@cy"
                                 rx="@(size * 0.8)"
                                 ry="@(size * 0.38)"
                                 fill="none"
                                 stroke="#d7fbff"
                                 stroke-width="1.5"
                                 opacity="0.45"
                                 transform="rotate(-25 @cx @cy)" />
                        <circle cx="@(point.x + size * 0.18)" cy="@(point.y - size * 0.08)" r="@(Math.Max(1d, size * 0.07))" fill="#f8ffff" opacity="0.5" />
                    }
                    else
                    {
                        <circle cx="@cx" cy="@cy" r="@(Math.Max(2d, size * 0.12))" fill="#ffffff" opacity="0.2" />
                    }
                </g>
            }
        </g>

        <g id="rocket" transform="translate(550, 120)">
            <g fill="lightgray" fill-rule="evenodd" stroke="black" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" transform="translate(4 1)">
                <path d="m6.5 18.5c3-2.5021966 4-5.5021966 4-9 0-3.49780342-1-6.49780342-4-9-3 2.50219658-4 5.50219658-4 9 0 3.4978034 1 6.4978034 4 9z"/>
                <path fill="red" d="m10.0620355 13.3616971c.4244504.2452152.814833.5459803 1.1711478.9022951 1.1190122 1.1190122 1.6901459 2.5740294 1.7134011 4.3650515-2.5082701-.109848-3.88207621-.7645704-4.92553235-1.6471655m-5.11545113-3.6201811c-.42445038.2452152-.81483298.5459803-1.17114781.9022951-1.11901221 1.1190122-1.6901459 2.5740294-1.71340106 4.3650515 2.50827003-.109848 3.88207616-.7645704 4.9255323-1.6471655"/>
                <circle cx="6.5" cy="6.5" r="2" fill="cyan"/>
            </g>
        </g>
    </svg>

    <aside id="planet-info" class="planet-info">
        <div class="planet-panel-head">
            <h4 id="planet-info-name" class="planet-panel-title">Choose a Planet</h4>
            <button id="close-planet-panel" class="planet-panel-close" type="button" aria-label="Close">×</button>
        </div>
        <p id="planet-info-type" class="planet-info-type"></p>
        <p id="planet-info-description" class="planet-info-description"></p>
        <p id="planet-info-distance" class="planet-info-distance"></p>

        <div id="planet-actions" class="planet-actions hidden">
            <div class="planet-actions-title">Timer</div>
            <label class="planet-actions-label" for="planet-task-minutes">Minutes</label>
            <input id="planet-task-minutes" class="planet-actions-input" type="number" min="1" max="300" value="25" />
            <button id="planet-start-session" class="planet-action-btn" type="button">Start timer</button>
            <p id="planet-actions-note" class="planet-actions-note"></p>
        </div>
    </aside>

    <div id="planet-tooltip" class="planet-tooltip" aria-hidden="true"></div>
</div>

<div class="container mt-4 mb-4">
    <div class="d-flex justify-content-center mb-3">
        <a href="/Session" class="btn btn-outline-info" id="openFocusTimerBtn">Open Focus Timer</a>
    </div>
    <h3 class="text-center mb-4">Available Planets</h3>
    @if (Model is not null && Model.Any())
    {
        <div class="row g-3">
            @foreach (var planet in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 bg-dark text-light border-secondary">
                        <div class="card-body">
                            <h5 class="card-title">#@planet.OrderNumber @planet.Name</h5>
                            <p class="card-text text-secondary mb-2">
                                @(string.IsNullOrWhiteSpace(planet.Description) ? "No description" : planet.Description)
                            </p>
                            @if (planet.DistanceFromPrevious.HasValue)
                            {
                                <div class="small text-info">Distance: @planet.DistanceFromPrevious</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-center text-muted">No planets found.</p>
    }
</div>

<div class="focus-overlay" id="focusModal" aria-hidden="true">
    <div class="focus-modal" role="dialog" aria-modal="true" aria-label="Focus timer">
        <button class="focus-close" id="focusModalClose" type="button" aria-label="Close">x</button>
        <div class="focus-grid">
            <section class="focus-panel focus-tasks">
                <div class="focus-panel-header">
                    <h3 class="focus-panel-title">Tasks</h3>
                    <button class="focus-ghost-btn" id="refreshTasksBtn" type="button">Refresh</button>
                </div>
                <div class="task-search">
                    <input id="taskSearchInput" type="text" placeholder="Search tasks" />
                    <button class="focus-ghost-btn" id="clearTaskSelectionBtn" type="button">Clear</button>
                </div>
                <div id="selectedTaskDisplay" class="selected-task">Bound task: None</div>
                <div id="taskList" class="task-list"></div>
                <div id="taskEmpty" class="task-empty">No tasks yet.</div>
                <div class="task-create">
                    <div class="task-create-title">Create task</div>
                    <input id="newTaskTitle" type="text" placeholder="Task title" maxlength="300" />
                    <textarea id="newTaskDescription" placeholder="Task description (optional)" maxlength="2000"></textarea>
                    <button class="focus-primary-btn" id="createTaskBtn" type="button">Create task</button>
                    <div id="taskCreateNote" class="task-note"></div>
                </div>
            </section>
            <section class="focus-panel focus-timer">
                <div class="timer-shell">
                    <div class="timer-card" id="setup">
                        <div class="timer-header">
                            <h4 class="timer-title">Focus Timer</h4>
                            <p class="timer-subtitle">Pick a duration and press start.</p>
                        </div>

                        <label class="timer-label" for="minutesInput">Minutes</label>
                        <input type="number" id="minutesInput" class="timer-input" min="1" max="180" value="25" />
                        <div id="inputError" class="timer-error" style="display:none;"></div>

                        <button class="timer-primary" id="startTimerBtn" type="button">Start timer</button>
                        <div id="startError" class="timer-error" style="display:none;"></div>
                        <div id="taskBindingStatus" class="task-binding">Bound task: None</div>
                    </div>

                    <div class="timer-card" id="timerDisplay" style="display:none">
                        <div class="timer-header">
                            <h4 class="timer-title">Focusing...</h4>
                            <p id="activeTaskLabel" class="timer-subtitle"></p>
                        </div>
                        <div class="timer-count" id="timeLeft">00:00</div>
                        <div class="timer-actions">
                            <button class="timer-secondary" id="pauseBtn" type="button">Pause</button>
                            <button class="timer-danger" id="cancelBtn" type="button">Cancel</button>
                        </div>
                        <div id="cancelConfirm" class="timer-confirm" style="display:none;">
                            <p>Cancel this session?</p>
                            <div class="timer-actions">
                                <button class="timer-danger" id="confirmCancelBtn" type="button">Yes, cancel</button>
                                <button class="timer-secondary" id="cancelBackBtn" type="button">No</button>
                            </div>
                        </div>
                    </div>

                    <div class="timer-card" id="planetInfoCard" style="display:none">
                        <div class="planet-card-title">Planet</div>
                        <div class="planet-card-name" id="planetInfoName"></div>
                        <div class="planet-card-type" id="planetInfoType"></div>
                        <div class="planet-card-description" id="planetInfoDescription"></div>
                        <div class="planet-card-distance" id="planetInfoDistance"></div>
                    </div>

                    <div class="timer-card" id="doneMessage" style="display:none">
                        <div class="timer-done">OK</div>
                        <h4 class="timer-title">Session Complete!</h4>
                        <p class="timer-subtitle">Great work. Take a short break.</p>
                        <button class="timer-primary" id="resetTimerBtn" type="button">New session</button>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="text-center mt-4">
        <h2 class="mb-3">Welcome to FocusSpace</h2>
        <p class="text-muted mb-4">Track your focus sessions and explore the galaxy of productivity.</p>
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                Get Started
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">
                Log In
            </a>
        </div>
    </div>
}

<style>
    .space-stage {
        position: relative;
        width: min(1080px, 96vw);
        height: min(76vh, 740px);
        min-height: 520px;
        margin: 86px auto 0;
        border-radius: 16px;
        overflow: hidden;
        background:
            radial-gradient(circle at 20% 20%, rgba(125, 58, 237, 0.18), transparent 40%),
            radial-gradient(circle at 80% 80%, rgba(0, 173, 181, 0.14), transparent 45%),
            linear-gradient(180deg, #0e0f1a 0%, #14172a 100%);
        border: 1px solid rgba(124, 58, 237, 0.28);
    }

    #planet-visualization {
        display: block;
        width: 100%;
        height: 100%;
    }

    .planet {
        cursor: pointer;
        transition: transform 0.25s ease;
    }

    .planet circle {
        transition: stroke 0.2s ease, stroke-width 0.2s ease, filter 0.2s ease;
    }

    .planet:hover circle,
    .planet.selected circle,
    .planet:focus-visible circle {
        stroke: #ffffff;
        stroke-width: 2;
        filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.45));
    }

    .planet.type-rocky circle:first-child {
        stroke: rgba(230, 220, 185, 0.4);
        stroke-width: 0.8;
    }

    .planet.type-gas circle:first-child {
        stroke: rgba(250, 201, 112, 0.55);
        stroke-width: 1;
    }

    .planet.type-ice circle:first-child {
        stroke: rgba(126, 217, 255, 0.55);
        stroke-width: 1;
    }

    .planet.type-exo circle:first-child {
        stroke: rgba(186, 162, 255, 0.55);
        stroke-width: 1;
    }

    .planet-info {
        position: absolute;
        right: 14px;
        bottom: 14px;
        width: min(340px, calc(100% - 28px));
        max-height: calc(100% - 28px);
        background: rgba(12, 16, 30, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 12px;
        padding: 16px;
        color: #f0f2ff;
        backdrop-filter: blur(8px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        overflow-y: auto;
        transition: all 0.3s ease;
    }

    .planet-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 6px;
    }

    .planet-panel-title {
        margin: 0;
        font-size: 18px;
        color: #f2e9ff;
    }

    .planet-panel-close {
        background: none;
        border: none;
        color: #9aa0b6;
        font-size: 18px;
        cursor: pointer;
        padding: 0;
        display: none;
    }

    .planet-info h4 {
        margin: 0 0 6px;
        font-size: 18px;
    }

    .planet-info-type {
        margin: 0 0 8px;
        color: #ffd98e;
        font-weight: 600;
    }

    .planet-info-description {
        margin: 0 0 8px;
        color: #d6d9f0;
        font-size: 14px;
        line-height: 1.35;
    }

    .planet-info-distance {
        margin: 0;
        color: #8edcff;
        font-size: 13px;
    }

    .planet-actions {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .planet-actions.hidden {
        display: none;
    }

    .planet-actions-title {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: #b9c2ff;
        margin-bottom: 8px;
    }

    .planet-actions-label {
        display: block;
        font-size: 11px;
        color: #9aa0b6;
        margin-bottom: 4px;
    }

    .planet-actions-input {
        width: 100%;
        padding: 8px 10px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(10, 12, 24, 0.6);
        color: #f0f2ff;
        margin-bottom: 8px;
        font-size: 13px;
    }

    .planet-action-btn {
        width: 100%;
        padding: 9px 10px;
        border-radius: 8px;
        border: 1px solid transparent;
        background: #2f7bf6;
        color: #ffffff;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    }

    .planet-action-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        box-shadow: none;
        transform: none;
    }

    .planet-actions-note {
        margin: 8px 0 0;
        font-size: 11px;
        color: #8edcff;
        min-height: 14px;
    }

    .planet-tooltip {
        position: absolute;
        pointer-events: none;
        z-index: 5;
        display: none;
        max-width: 220px;
        background: rgba(7, 10, 20, 0.92);
        color: #f5f7ff;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 10px;
        padding: 10px 12px;
        box-shadow: 0 16px 32px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(8px);
        font-size: 13px;
        line-height: 1.35;
    }

    .planet-tooltip strong {
        display: block;
        font-size: 14px;
        margin-bottom: 4px;
        color: #ffd98e;
    }

    .planet-tooltip .tooltip-meta {
        color: #9fdcff;
        margin-top: 6px;
    }

    @@media (max-width: 768px) {
        .space-stage {
            margin-top: 74px;
            min-height: 440px;
            height: 68vh;
        }

        .planet-info {
            position: static;
            width: calc(100% - 24px);
            margin: 12px;
        }
    }

    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .timer-shell {
        width: min(520px, 92vw);
        margin: 40px auto 60px;
        display: grid;
        gap: 18px;
    }

    .timer-card {
        background: linear-gradient(160deg, rgba(24, 26, 48, 0.95), rgba(16, 18, 34, 0.95));
        border: 1px solid rgba(168, 139, 250, 0.25);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
        color: #e8e9ff;
        text-align: center;
    }

    .timer-header {
        margin-bottom: 18px;
    }

    .timer-title {
        margin: 0 0 6px;
        font-size: 20px;
        color: #cdb7ff;
        letter-spacing: 0.5px;
    }

    .timer-subtitle {
        margin: 0;
        color: #9a9fc2;
        font-size: 13px;
    }

    .timer-label {
        display: block;
        text-align: left;
        font-size: 12px;
        color: #9a9fc2;
        margin-bottom: 6px;
    }

    .timer-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid rgba(130, 122, 182, 0.4);
        background: rgba(12, 14, 26, 0.8);
        color: #e8e9ff;
        margin-bottom: 12px;
        text-align: center;
        font-size: 16px;
    }

    .timer-primary,
    .timer-secondary,
    .timer-danger {
        width: 100%;
        padding: 12px 14px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    }

    .timer-primary {
        background: #7c3aed;
        color: #fff;
        box-shadow: 0 10px 20px rgba(124, 58, 237, 0.35);
    }

    .timer-secondary {
        background: rgba(31, 33, 54, 0.9);
        color: #d9dbf5;
        border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .timer-danger {
        background: rgba(239, 68, 68, 0.9);
        color: #fff;
    }

    .timer-actions {
        display: grid;
        gap: 10px;
        margin-top: 16px;
    }

    .timer-count {
        font-size: 54px;
        font-weight: 700;
        letter-spacing: 4px;
        color: #a78bfa;
        margin: 16px 0;
    }

    .timer-error {
        color: #f87171;
        font-size: 12px;
        margin-bottom: 10px;
    }

    .timer-confirm {
        margin-top: 14px;
        color: #c8cbee;
    }

    .timer-done {
        font-size: 36px;
        margin-bottom: 10px;
    }

    .planet-card-title {
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 1px;
        color: #9a9fc2;
        margin-bottom: 10px;
    }

    .planet-card-name {
        font-size: 18px;
        font-weight: 700;
