    @@media (max-width: 900px) {
        .focus-grid {
            grid-template-columns: 1fr;
            overflow-y: auto;
            max-height: 86vh;
        }
    }
</style>

@section Scripts {
    <script>
        const rocket = document.getElementById('rocket');
        const planetsOrbit = document.getElementById('planets-orbit');
        const planetNodes = Array.from(document.querySelectorAll('.planet'));
        const svgElement = document.getElementById('planet-visualization');
        const centerX = parseFloat(svgElement.dataset.centerX || '510');
        const centerY = parseFloat(svgElement.dataset.centerY || '360');
        const spaceStage = document.querySelector('.space-stage');
        const planetTooltip = document.getElementById('planet-tooltip');
        const defaultViewBox = { x: 0, y: 0, width: 1020, height: 820 };

        const infoName = document.getElementById('planet-info-name');
        const infoType = document.getElementById('planet-info-type');
        const infoDescription = document.getElementById('planet-info-description');
        const infoDistance = document.getElementById('planet-info-distance');
        const closePlanetPanel = document.getElementById('close-planet-panel');
        const planetActions = document.getElementById('planet-actions');
        const taskMinutesInput = document.getElementById('planet-task-minutes');
        const startSessionButton = document.getElementById('planet-start-session');
        const actionsNote = document.getElementById('planet-actions-note');
        const isAuthenticated = @((User.Identity?.IsAuthenticated ?? false).ToString().ToLowerInvariant());
        const zoomEnabled = true; // Enable zoom on planet selection

        let currentX = 550;
        let currentY = 120;
        let currentRotation = 0;
        let isTraveling = false;
        let activeOrbitPlanet = null;
        let orbitStartTime = null;
        let orbitRadius = 34;
        let travelStartTime = null;
        let travelDuration = 700;
        let travelFrom = { x: currentX, y: currentY };
        let travelTo = { x: currentX, y: currentY };
        let travelTargetPlanet = null;
        let orbitAnimationId = null;
        let travelAnimationId = null;
        let zoomAnimationId = null;
        let currentTooltipPlanet = null;
        let selectedPlanetId = null;

        function getToken() {
            return document.querySelector('#af-form input[name="__RequestVerificationToken"]')?.value || '';
        }

        function setActionState(enabled) {
            const disabled = !enabled || !isAuthenticated;
            taskMinutesInput.disabled = disabled;
            startSessionButton.disabled = disabled;

            if (!isAuthenticated) {
                actionsNote.textContent = 'Log in to start the timer.';
            } else if (!enabled) {
                actionsNote.textContent = 'Select a planet to enable the timer.';
            } else {
                actionsNote.textContent = '';
            }
        }
        function getOrbitRotationRad() {
            const transform = window.getComputedStyle(planetsOrbit).transform;
            if (!transform || transform === 'none') return 0;

            const match = transform.match(/matrix\(([^)]+)\)/);
            if (!match || !match[1]) return 0;

            const values = match[1].split(',').map(v => parseFloat(v.trim()));
            if (values.length < 2) return 0;

            return Math.atan2(values[1], values[0]);
        }

        function getActualPlanetPosition(planet) {
            const cx = parseFloat(planet.dataset.cx || '0');
            const cy = parseFloat(planet.dataset.cy || '0');
            const orbitRotation = getOrbitRotationRad();

            const dx = cx - centerX;
            const dy = cy - centerY;
            const distance = Math.sqrt(dx * dx + dy * dy);
            const angle = Math.atan2(dy, dx) + orbitRotation;

            return {
                x: centerX + distance * Math.cos(angle),
                y: centerY + distance * Math.sin(angle)
            };
        }

        function getOrbitRadius(planet) {
            const radiusFromData = parseFloat(planet.dataset.radius || '16');
            return Math.max(20, radiusFromData + 18);
        }

        function getOrbitAnchor(planet) {
            const center = getActualPlanetPosition(planet);
            const angle = -Math.PI / 3;
            const radius = getOrbitRadius(planet);

            return {
                x: center.x + radius * Math.cos(angle),
                y: center.y + radius * Math.sin(angle),
                angle
            };
        }

        function setRocketTransform(x, y, rotation) {
            currentX = x;
            currentY = y;
            currentRotation = rotation;
            rocket.setAttribute('transform', `translate(${x}, ${y}) rotate(${rotation})`);
        }

        function setSelectedPlanet(planet) {
            planetNodes.forEach(p => p.classList.remove('selected'));
            planet.classList.add('selected');

            const name = planet.dataset.name || 'Unknown';
            const type = planet.dataset.type || 'Unknown';
            const order = planet.dataset.order || '-';
            const description = (planet.dataset.description || '').trim();
            const distance = (planet.dataset.distance || '').trim();

            infoName.textContent = `#${order} ${name}`;
            infoType.textContent = `Type: ${type}`;
            infoDescription.textContent = description || 'No description provided for this planet.';
            infoDistance.textContent = distance
                ? `Distance from previous: ${distance}`
                : 'Distance from previous: not specified';

            // Show close button when planet is selected
            closePlanetPanel.style.display = 'block';
            selectedPlanetId = planet.dataset.id || null;
            planetActions.classList.remove('hidden');
            setActionState(true);
        }

        function showTooltip(planet, event) {
            currentTooltipPlanet = planet;

            const name = planet.dataset.name || 'Unknown';
            const type = planet.dataset.type || 'Unknown';
            const order = planet.dataset.order || '-';
            const description = (planet.dataset.description || '').trim() || 'No description provided.';
            const distance = (planet.dataset.distance || '').trim();

            planetTooltip.innerHTML = `
                <strong>#${order} ${name}</strong>
                <div>Type: ${type}</div>
                <div>${description}</div>
                <div class="tooltip-meta">${distance ? `Distance: ${distance}` : 'Distance: not specified'}</div>
            `;
            planetTooltip.style.display = 'block';
            updateTooltipPosition(event);
        }

        function updateTooltipPosition(event) {
            if (!currentTooltipPlanet) return;

            const rect = spaceStage.getBoundingClientRect();
            const tooltipWidth = planetTooltip.offsetWidth || 220;
            const tooltipHeight = planetTooltip.offsetHeight || 90;

            let left = event.clientX - rect.left + 16;
            let top = event.clientY - rect.top + 16;

            if (left + tooltipWidth > rect.width) left = event.clientX - rect.left - tooltipWidth - 16;
            if (top + tooltipHeight > rect.height) top = event.clientY - rect.top - tooltipHeight - 16;

            left = Math.max(10, left);
            top = Math.max(10, top);

            planetTooltip.style.left = `${left}px`;
            planetTooltip.style.top = `${top}px`;
        }

        function hideTooltip() {
            currentTooltipPlanet = null;
            planetTooltip.style.display = 'none';
        }

        function stopOrbit() {
            if (orbitAnimationId !== null) {
                cancelAnimationFrame(orbitAnimationId);
                orbitAnimationId = null;
            }
        }

        function stopTravel() {
            if (travelAnimationId !== null) {
                cancelAnimationFrame(travelAnimationId);
                travelAnimationId = null;
            }
        }

        function stopZoom() {
            if (zoomAnimationId !== null) {
                cancelAnimationFrame(zoomAnimationId);
                zoomAnimationId = null;
            }
        }

        function setViewBox(box) {
            svgElement.setAttribute(
                'viewBox',
                `${box.x.toFixed(2)} ${box.y.toFixed(2)} ${box.width.toFixed(2)} ${box.height.toFixed(2)}`
            );
        }

        function animateZoomToPlanet(planet) {
            stopZoom();

            const center = getActualPlanetPosition(planet);
            const planetRadius = getOrbitRadius(planet);
            const targetWidth = Math.max(360, planetRadius * 7.2);
            const targetHeight = Math.max(320, planetRadius * 5.8);

            const maxX = Math.max(0, 1020 - targetWidth);
            const maxY = Math.max(0, 820 - targetHeight);

            const target = {
                x: Math.min(Math.max(0, center.x - targetWidth / 2), maxX),
                y: Math.min(Math.max(0, center.y - targetHeight / 2), maxY),
                width: targetWidth,
                height: targetHeight
            };

            const start = { ...defaultViewBox };
            const duration = 900;
            let startTime = null;

            function easeInOut(t) {
                return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
            }

            function step(now) {
                if (!startTime) startTime = now;

                const progress = Math.min((now - startTime) / duration, 1);
                const eased = easeInOut(progress);
                const box = {
                    x: start.x + (target.x - start.x) * eased,
                    y: start.y + (target.y - start.y) * eased,
                    width: start.width + (target.width - start.width) * eased,
                    height: start.height + (target.height - start.height) * eased
                };

                setViewBox(box);

                if (progress < 1) {
                    zoomAnimationId = requestAnimationFrame(step);
                    return;
                }

                zoomAnimationId = null;
            }

            zoomAnimationId = requestAnimationFrame(step);
        }

        function resetZoom() {
            stopZoom();
            setViewBox(defaultViewBox);
        }

        function animateTravelToPlanet(planet) {
            stopTravel();
            stopOrbit();
            resetZoom();

            isTraveling = true;
            travelTargetPlanet = planet;
            travelStartTime = null;
            travelFrom = { x: currentX, y: currentY };

            const anchor = getOrbitAnchor(planet);
            travelTo = { x: anchor.x, y: anchor.y };

            const dx = travelTo.x - travelFrom.x;
            const dy = travelTo.y - travelFrom.y;
            const heading = Math.atan2(dy, dx) * 180 / Math.PI + 90;

            function step(now) {
                if (!travelStartTime) travelStartTime = now;

                const progress = Math.min((now - travelStartTime) / travelDuration, 1);
                const eased = progress < 0.5
                    ? 2 * progress * progress
                    : 1 - Math.pow(-2 * progress + 2, 2) / 2;

                const x = travelFrom.x + (travelTo.x - travelFrom.x) * eased;
                const y = travelFrom.y + (travelTo.y - travelFrom.y) * eased;
                const rotation = Math.atan2(y - currentY, x - currentX) * 180 / Math.PI + 90;
                setRocketTransform(x, y, Number.isFinite(rotation) ? rotation : heading);

                if (progress < 1) {
                    travelAnimationId = requestAnimationFrame(step);
                    return;
                }

                travelAnimationId = null;
                isTraveling = false;
                activeOrbitPlanet = travelTargetPlanet;
                orbitRadius = getOrbitRadius(activeOrbitPlanet);
                orbitStartTime = null;
                if (zoomEnabled) {
                    animateZoomToPlanet(activeOrbitPlanet);
                }

                // Start orbiting immediately after arrival
                startOrbitLoop();
            }

            travelAnimationId = requestAnimationFrame(step);
        }

        function startOrbitLoop() {
            stopOrbit();

            const orbitDuration = 2600;
            let lastFrameTime = null;

            function animateOrbit(now) {
                if (!activeOrbitPlanet) {
                    orbitAnimationId = null;
                    return;
                }

                // Initialize timing on first frame
                if (!orbitStartTime) {
                    orbitStartTime = now;
                }

                // Only animate orbit if we're not traveling
                if (!isTraveling) {
                    const elapsed = now - orbitStartTime;
                    const progress = (elapsed % orbitDuration) / orbitDuration;
                    const angle = progress * Math.PI * 2;
                    
                    const center = getActualPlanetPosition(activeOrbitPlanet);
                    const x = center.x + orbitRadius * Math.cos(angle);
                    const y = center.y + orbitRadius * Math.sin(angle);
                    
                    const nextAngle = angle + 0.03;
                    const nx = center.x + orbitRadius * Math.cos(nextAngle);
                    const ny = center.y + orbitRadius * Math.sin(nextAngle);
                    
                    const heading = Math.atan2(ny - y, nx - x) * 180 / Math.PI + 90;
                    setRocketTransform(x, y, Number.isFinite(heading) ? heading : 0);
                }

                orbitAnimationId = requestAnimationFrame(animateOrbit);
            }

            orbitAnimationId = requestAnimationFrame(animateOrbit);
        }

        function selectPlanet(planet) {
            setSelectedPlanet(planet);
            animateTravelToPlanet(planet);
        }

        function hidePlanetPanel() {
            planetNodes.forEach(p => p.classList.remove('selected'));
            closePlanetPanel.style.display = 'none';
            selectedPlanetId = null;
            setActionState(false);
            planetActions.classList.add('hidden');
            infoName.textContent = 'Choose a Planet';
            infoType.textContent = 'Click any planet to inspect it.';
            infoDescription.textContent = 'The rocket will fly to the selected planet and start circling around it.';
            infoDistance.textContent = '';
            resetZoom();
        }

        // Close panel button
        closePlanetPanel.addEventListener('click', hidePlanetPanel);

        function getSelectedPlanetInfo() {
            if (!selectedPlanetId) return null;

            const node = planetNodes.find(p => p.dataset.id === String(selectedPlanetId));
            if (!node) return null;

            return {
                id: node.dataset.id || '',
                name: node.dataset.name || '',
                type: node.dataset.type || '',
                description: (node.dataset.description || '').trim(),
                distance: (node.dataset.distance || '').trim()
            };
        }

        function storeActiveSessionPlanetInfo(sessionId, planetInfo) {
            if (!sessionId || !planetInfo) return;

            const payload = {
                sessionId: String(sessionId),
                planetInfo,
                storedAt: new Date().toISOString()
            };

            localStorage.setItem('activeSessionPlanet', JSON.stringify(payload));
        }

        async function openActiveSession() {
            const res = await fetch('/Session/GetActiveSession');
            if (!res.ok) return false;

            const data = await res.json().catch(() => null);
            if (!data || !data.hasActive || !data.sessionId) return false;

            if (data.taskId) {
                setSelectedTaskById(data.taskId, data.label || '');
            } else {
                clearTaskSelection();
            }

            const plannedSeconds = Number(data.plannedSeconds || 0);
            const remainingSeconds = Number(data.remainingSeconds || 0);
            const minutes = plannedSeconds > 0 ? Math.ceil(plannedSeconds / 60) : 25;

            await startTimer({
                minutes,
                sessionId: data.sessionId,
                label: data.label || '',
                plannedSeconds,
                remainingSeconds,
                taskId: data.taskId || null
            });
            return true;
        }

        async function startSessionFromPanel() {
            if (!selectedPlanetId) return;

            const minutes = parseInt(taskMinutesInput.value, 10) || 25;

            actionsNote.textContent = 'Opening timer...';

            const planetInfo = getSelectedPlanetInfo();
            openFocusModal();
            await startTimer({
                minutes,
                planetInfo
            });

            actionsNote.textContent = '';
        }

        startSessionButton.addEventListener('click', startSessionFromPanel);
        setActionState(false);

        planetNodes.forEach(planet => {
            planet.addEventListener('click', () => selectPlanet(planet));
            planet.addEventListener('mouseenter', event => showTooltip(planet, event));
            planet.addEventListener('mousemove', event => updateTooltipPosition(event));
            planet.addEventListener('mouseleave', hideTooltip);
            planet.addEventListener('keydown', e => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    selectPlanet(planet);
                }
            });
        });

        const initialPlanet =
            planetNodes.find(p => (p.dataset.name || '').toLowerCase() === 'earth') ||
            planetNodes[0] ||
            null;

        if (initialPlanet) {
            setSelectedPlanet(initialPlanet);
            const initialPos = getActualPlanetPosition(initialPlanet);
            activeOrbitPlanet = initialPlanet;
            orbitRadius = getOrbitRadius(initialPlanet);
            setRocketTransform(initialPos.x + orbitRadius, initialPos.y, 90);
            resetZoom();
            startOrbitLoop();
        }

        const focusModal = document.getElementById('focusModal');
        const focusModalClose = document.getElementById('focusModalClose');
        const startTimerBtn = document.getElementById('startTimerBtn');
        const pauseBtn = document.getElementById('pauseBtn');
        const cancelBtn = document.getElementById('cancelBtn');
        const confirmCancelBtn = document.getElementById('confirmCancelBtn');
        const cancelBackBtn = document.getElementById('cancelBackBtn');
        const resetTimerBtn = document.getElementById('resetTimerBtn');

        const taskListEl = document.getElementById('taskList');
        const taskEmptyEl = document.getElementById('taskEmpty');
        const taskSearchInput = document.getElementById('taskSearchInput');
        const refreshTasksBtn = document.getElementById('refreshTasksBtn');
        const clearTaskSelectionBtn = document.getElementById('clearTaskSelectionBtn');
        const selectedTaskDisplay = document.getElementById('selectedTaskDisplay');
        const taskBindingStatus = document.getElementById('taskBindingStatus');
        const newTaskTitle = document.getElementById('newTaskTitle');
        const newTaskDescription = document.getElementById('newTaskDescription');
        const createTaskBtn = document.getElementById('createTaskBtn');
        const taskCreateNote = document.getElementById('taskCreateNote');

        const planetInfoCard = document.getElementById('planetInfoCard');
        const planetInfoName = document.getElementById('planetInfoName');
        const planetInfoType = document.getElementById('planetInfoType');
        const planetInfoDescription = document.getElementById('planetInfoDescription');
        const planetInfoDistance = document.getElementById('planetInfoDistance');

        const minutesInput = document.getElementById('minutesInput');
        const activeTaskLabel = document.getElementById('activeTaskLabel');

        let allTasks = [];
        let selectedTaskId = null;
        let selectedTaskTitle = '';

        let intervalId = null;
        let secondsLeft = 0;
        let totalSeconds = 0;
        let currentSessionId = null;
        let isPaused = false;

        function openFocusModal() {
            if (!focusModal) return;
            focusModal.classList.add('active');
            focusModal.setAttribute('aria-hidden', 'false');
            document.body.classList.add('focus-open');
            loadTasks();
            updateSelectedTaskDisplay();
        }

        function closeFocusModal() {
            if (!focusModal) return;
            focusModal.classList.remove('active');
            focusModal.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('focus-open');
        }

        function updateSelectedTaskDisplay() {
            if (!selectedTaskDisplay) return;
            const boundLabel = selectedTaskTitle
                ? `Bound task: ${selectedTaskTitle}`
                : 'Bound task: None';

            selectedTaskDisplay.textContent = boundLabel;
            if (taskBindingStatus) taskBindingStatus.textContent = boundLabel;

            if (!currentSessionId) {
                activeTaskLabel.textContent = selectedTaskTitle
                    ? `Bound task: ${selectedTaskTitle}`
                    : 'No task bound';
            }
        }

        function clearTaskSelection() {
            selectedTaskId = null;
            selectedTaskTitle = '';
            updateSelectedTaskDisplay();
            renderTasks();
        }

        function setSelectedTaskById(taskId, title) {
            selectedTaskId = taskId;
            selectedTaskTitle = title || '';
            updateSelectedTaskDisplay();
            renderTasks();
        }

        function selectTask(task) {
            selectedTaskId = task.id;
            selectedTaskTitle = task.title;
            updateSelectedTaskDisplay();
            renderTasks();
        }

        function renderTasks() {
            if (!taskListEl || !taskSearchInput) return;

            const term = taskSearchInput.value.trim().toLowerCase();
            const filtered = allTasks.filter(t => {
                const title = (t.title || '').toLowerCase();
                const desc = (t.description || '').toLowerCase();
                return !term || title.includes(term) || desc.includes(term);
            });

            if (!filtered.length) {
                taskListEl.innerHTML = '';
                taskEmptyEl.style.display = 'block';
                return;
            }

            taskEmptyEl.style.display = 'none';
            taskListEl.innerHTML = filtered.map(t => {
                const selectedClass = t.id === selectedTaskId ? ' selected' : '';
                const desc = t.description ? escapeHtml(t.description) : 'No description';
                const boundBadge = t.id === selectedTaskId ? '<div class="task-bound">Bound to timer</div>' : '';
                return `
                    <div class="task-item${selectedClass}" data-id="${t.id}">
                        <div class="task-header">
                            <div class="task-title">${escapeHtml(t.title)}</div>
                            <button class="task-delete-btn" data-id="${t.id}" type="button">Delete</button>
                        </div>
                        <div class="task-description">${desc}</div>
                        ${boundBadge}
                    </div>`;
            }).join('');

            taskListEl.querySelectorAll('.task-item').forEach(el => {
                el.addEventListener('click', () => {
                    const id = parseInt(el.dataset.id || '0', 10);
                    const task = allTasks.find(t => t.id === id);
                    if (task) selectTask(task);
                });
            });

            taskListEl.querySelectorAll('.task-delete-btn').forEach(btn => {
                btn.addEventListener('click', (event) => {
                    event.stopPropagation();
                    const id = parseInt(btn.dataset.id || '0', 10);
                    if (id) deleteTaskById(id);
                });
            });
        }

        async function loadTasks() {
            if (!taskListEl || !taskEmptyEl) return;

            if (!isAuthenticated) {
                allTasks = [];
                taskListEl.innerHTML = '';
                taskEmptyEl.textContent = 'Log in to manage tasks.';
                taskEmptyEl.style.display = 'block';
                return;
            }

            try {
                const res = await fetch('/Tasks/GetUserTasks');
                if (!res.ok) throw new Error('Failed to load tasks');
                allTasks = await res.json();
                renderTasks();
            } catch {
                taskListEl.innerHTML = '';
                taskEmptyEl.textContent = 'Could not load tasks.';
                taskEmptyEl.style.display = 'block';
            }
        }

        async function createTask() {
            if (!isAuthenticated) return;
            const title = (newTaskTitle?.value || '').trim();
            const description = (newTaskDescription?.value || '').trim();

            if (!title) {
                taskCreateNote.textContent = 'Title is required.';
                return;
            }

            taskCreateNote.textContent = 'Creating task...';

            const res = await fetch('/Tasks/CreateJson', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                },
                body: JSON.stringify({
                    title,
                    description: description || null
                })
            });

            const data = await res.json().catch(() => null);
            if (!res.ok) {
                taskCreateNote.textContent = data?.message || 'Could not create task.';
                return;
            }

            newTaskTitle.value = '';
            newTaskDescription.value = '';
            taskCreateNote.textContent = 'Task created.';
            await loadTasks();
            if (data?.id) setSelectedTaskById(data.id, title);
        }

        async function deleteTaskById(taskId) {
            if (!isAuthenticated) return;
            if (!confirm('Delete this task?')) return;

            const res = await fetch('/Tasks/DeleteJson', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                },
                body: JSON.stringify({ id: taskId })
            });

            const data = await res.json().catch(() => null);
            if (!res.ok) {
                alert(data?.message || 'Could not delete task.');
                return;
            }

            if (selectedTaskId === taskId) {
                clearTaskSelection();
            }

            await loadTasks();
        }

        function getPlanetInfoFromParams(params) {
            const name = params.get('planetName');
            const type = params.get('planetType');
            const description = params.get('planetDescription');
            const distance = params.get('planetDistance');

            if (!name && !type && !description && !distance) return null;

            return {
                name: name ? decodeURIComponent(name) : '',
                type: type ? decodeURIComponent(type) : '',
                description: description ? decodeURIComponent(description) : '',
                distance: distance ? decodeURIComponent(distance) : ''
            };
        }

        function loadPlanetInfoForSession(sessionId) {
            if (!sessionId) return null;

            const raw = localStorage.getItem('activeSessionPlanet');
            if (!raw) return null;

            try {
                const parsed = JSON.parse(raw);
                if (parsed?.sessionId === String(sessionId)) return parsed.planetInfo;
            } catch {
                return null;
            }

            return null;
        }

        function clearPlanetInfoForSession(sessionId) {
            if (!sessionId) return;

            const raw = localStorage.getItem('activeSessionPlanet');
            if (!raw) return;

            try {
                const parsed = JSON.parse(raw);
                if (parsed?.sessionId === String(sessionId)) {
                    localStorage.removeItem('activeSessionPlanet');
                }
            } catch {
            }
        }

        function applyPlanetInfo(info) {
            if (!planetInfoCard) return;

            if (!info || !(info.name || info.type || info.description || info.distance)) {
                planetInfoCard.style.display = 'none';
                return;
            }

            planetInfoName.textContent = info.name || 'Planet';
            planetInfoType.textContent = info.type ? `Type: ${info.type}` : '';
            planetInfoDescription.textContent = info.description || '';
            planetInfoDistance.textContent = info.distance ? `Distance: ${info.distance}` : '';
            planetInfoCard.style.display = 'block';
        }

        function showError(elementId, message) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.textContent = message;
            el.style.display = 'block';
        }

        function hideError(elementId) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.textContent = '';
            el.style.display = 'none';
        }

        async function startTimer(options = {}) {
            hideError('inputError');
            hideError('startError');

            if (!isAuthenticated) {
                showError('startError', 'Log in to start the timer.');
                return;
            }

            if (intervalId) {
                clearInterval(intervalId);
                intervalId = null;
            }

            const plannedSecondsOption = Number.isFinite(options.plannedSeconds) && options.plannedSeconds > 0
                ? options.plannedSeconds
                : null;
            const minutes = Number.isFinite(options.minutes) && options.minutes > 0
                ? options.minutes
                : (plannedSecondsOption ? Math.ceil(plannedSecondsOption / 60) : parseInt(minutesInput.value, 10));
            if (!minutes || minutes < 1) {
                showError('inputError', 'Please enter a valid number of minutes.');
                return;
            }

            const plannedSeconds = plannedSecondsOption ?? (minutes * 60);
            const remainingSeconds = Number.isFinite(options.remainingSeconds) && options.remainingSeconds >= 0
                ? Math.min(options.remainingSeconds, plannedSeconds)
                : plannedSeconds;
            minutesInput.value = Math.ceil(plannedSeconds / 60);

            const providedSessionId = options.sessionId ? parseInt(options.sessionId, 10) : null;
            const taskId = options.taskId ?? selectedTaskId ?? null;
            const label = options.label || selectedTaskTitle || '';

            if (taskId && label) setSelectedTaskById(taskId, label);

            if (!providedSessionId) {
                const payload = {
                    taskId,
                    plannedMinutes: minutes
                };

                let res = await fetch('/Session/Start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (res.status === 409) {
                    const replaceExisting = confirm('An active session already exists. Click OK to close it and start a new one, or Cancel to open the active session.');
                    if (replaceExisting) {
                        res = await fetch('/Session/Start', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                ...payload,
                                closeExisting: true
                            })
                        });
                    } else {
                        const opened = await openActiveSession();
                        if (!opened) showError('startError', 'Active session not found.');
                        return;
                    }
                }

                if (!res.ok) {
                    const errText = await res.text().catch(() => '');
                    console.error('Start session failed:', res.status, errText);
                    showError('startError', 'Failed to start session. Please try again.');
                    return;
                }

                const data = await res.json();
                currentSessionId = data.sessionId;
            } else {
                currentSessionId = providedSessionId;
            }

            if (options.planetInfo) {
                storeActiveSessionPlanetInfo(currentSessionId, options.planetInfo);
            }

            applyPlanetInfo(loadPlanetInfoForSession(currentSessionId));

            totalSeconds = plannedSeconds;
            secondsLeft = remainingSeconds;
            isPaused = false;

            const boundLabel = label || selectedTaskTitle;
            activeTaskLabel.textContent = boundLabel
                ? `Bound task: ${boundLabel}`
                : 'No task bound';
            document.getElementById('setup').style.display = 'none';
            document.getElementById('timerDisplay').style.display = 'block';
            document.getElementById('doneMessage').style.display = 'none';
            updateDisplay();

            if (secondsLeft <= 0) {
                await finishTimer(true);
                return;
            }

            intervalId = setInterval(() => {
                secondsLeft--;
                updateDisplay();
                if (secondsLeft <= 0) finishTimer(true);
            }, 1000);
        }

        async function togglePause() {
            if (!currentSessionId) return;

            if (!isPaused) {
                clearInterval(intervalId);
                intervalId = null;
                isPaused = true;
                pauseBtn.textContent = 'Resume';

                await fetch('/Session/Pause', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(currentSessionId)
                });
            } else {
                isPaused = false;
                pauseBtn.textContent = 'Pause';

                await fetch('/Session/Resume', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(currentSessionId)
                });

                intervalId = setInterval(() => {
                    secondsLeft--;
                    updateDisplay();
                    if (secondsLeft <= 0) finishTimer(true);
                }, 1000);
            }
        }

        function updateDisplay() {
            const m = String(Math.floor(secondsLeft / 60)).padStart(2, '0');
            const s = String(secondsLeft % 60).padStart(2, '0');
            document.getElementById('timeLeft').textContent = `${m}:${s}`;
        }

        async function finishTimer(completed) {
            if (intervalId) {
                clearInterval(intervalId);
                intervalId = null;
            }

            hideCancelConfirm();

            if (!currentSessionId) {
                resetTimer();
                return;
            }

            await fetch('/Session/Complete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: currentSessionId,
                    status: completed ? 'Completed' : 'Aborted',
                    endTime: new Date().toISOString(),
                    actualDuration: formatDuration(totalSeconds - secondsLeft)
                })
            });

            if (completed && selectedTaskId) {
                await loadTasks();
                clearTaskSelection();
            }

            clearPlanetInfoForSession(currentSessionId);
            applyPlanetInfo(null);

            document.getElementById('timerDisplay').style.display = 'none';
            if (completed) {
                document.getElementById('doneMessage').style.display = 'block';
            } else {
                resetTimer();
            }
        }

        function cancelTimer() {
            document.getElementById('cancelConfirm').style.display = 'block';
        }

        function hideCancelConfirm() {
            document.getElementById('cancelConfirm').style.display = 'none';
        }

        function resetTimer() {
            currentSessionId = null;
            isPaused = false;
            document.getElementById('doneMessage').style.display = 'none';
            document.getElementById('timerDisplay').style.display = 'none';
            document.getElementById('setup').style.display = 'block';
            applyPlanetInfo(null);
            updateSelectedTaskDisplay();
        }

        function formatDuration(seconds) {
            const h = String(Math.floor(seconds / 3600)).padStart(2, '0');
            const m = String(Math.floor((seconds % 3600) / 60)).padStart(2, '0');
            const s = String(seconds % 60).padStart(2, '0');
            return `${h}:${m}:${s}`;
        }

        function escapeHtml(value) {
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;');
        }

        function openFocusFromQuery() {
            const params = new URLSearchParams(window.location.search);
            const shouldOpen = params.get('focus') === '1' || params.get('autostart') === '1' || params.get('sessionId');
            if (!shouldOpen) return;

            openFocusModal();

            const sessionIdParam = params.get('sessionId');
            if (sessionIdParam) {
                const minutesParam = parseInt(params.get('minutes') || '', 10);
                const plannedSecondsParam = parseInt(params.get('plannedSeconds') || '', 10);
                const remainingSecondsParam = parseInt(params.get('remainingSeconds') || '', 10);
                const labelParam = params.get('label');
                const planetInfoFromParams = getPlanetInfoFromParams(params);

                const plannedSeconds = Number.isFinite(plannedSecondsParam) && plannedSecondsParam > 0
                    ? plannedSecondsParam
                    : null;
                const remainingSeconds = Number.isFinite(remainingSecondsParam) && remainingSecondsParam >= 0
                    ? remainingSecondsParam
                    : null;
                const minutes = Number.isFinite(minutesParam) && minutesParam > 0
                    ? minutesParam
                    : (plannedSeconds ? Math.ceil(plannedSeconds / 60) : 25);
                const label = labelParam ? decodeURIComponent(labelParam) : '';

                startTimer({
                    minutes,
                    sessionId: sessionIdParam,
                    label,
                    plannedSeconds,
                    remainingSeconds,
                    planetInfo: planetInfoFromParams
                });
                return;
            }

            openActiveSession();
        }

        if (focusModalClose) {
            focusModalClose.addEventListener('click', closeFocusModal);
        }

        if (focusModal) {
            focusModal.addEventListener('click', (event) => {
                if (event.target === focusModal) closeFocusModal();
            });
        }

        if (startTimerBtn) startTimerBtn.addEventListener('click', () => startTimer());
        if (pauseBtn) pauseBtn.addEventListener('click', togglePause);
        if (cancelBtn) cancelBtn.addEventListener('click', cancelTimer);
        if (confirmCancelBtn) confirmCancelBtn.addEventListener('click', () => finishTimer(false));
        if (cancelBackBtn) cancelBackBtn.addEventListener('click', hideCancelConfirm);
        if (resetTimerBtn) resetTimerBtn.addEventListener('click', resetTimer);

        if (taskSearchInput) taskSearchInput.addEventListener('input', renderTasks);
        if (refreshTasksBtn) refreshTasksBtn.addEventListener('click', loadTasks);
        if (clearTaskSelectionBtn) clearTaskSelectionBtn.addEventListener('click', clearTaskSelection);
        if (createTaskBtn) createTaskBtn.addEventListener('click', createTask);

        if (!isAuthenticated) {
            if (startTimerBtn) startTimerBtn.disabled = true;
            if (createTaskBtn) createTaskBtn.disabled = true;
        }

        const openFocusTimerBtn = document.getElementById('openFocusTimerBtn');
        if (openFocusTimerBtn) {
            openFocusTimerBtn.addEventListener('click', async (event) => {
                event.preventDefault();
                openFocusModal();
                await openActiveSession();
            });
        }

        openFocusFromQuery();
    </script>
}
